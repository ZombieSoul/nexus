# .codox/config — codox project configuration
#
# codox index/update with no args reads this file automatically.
#
#   output = <index filename>          (default: project.codex)
#
#   [[paths]]                          (repeat for each source directory)
#   dir = <path>                       (relative to .codox/ location)
#   lang = auto|cpp|py|tscript         (language filter)
output = modpack.codex

[[paths]]
dir = custom-mods/src
lang = auto

[[paths]]
dir = scripts
lang = auto

[[paths]]
dir = kubejs
lang = auto
