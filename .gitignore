# Mod jars - track only configs and source, not binaries
mods/*.jar
!mods/.gitkeep

# Build outputs
custom-mods/build/
custom-mods/.gradle/
custom-mods/out/
custom-mods/*.iml
custom-mods/.idea/

# OS junk
.DS_Store
Thumbs.db

# Minecraft runtime
run/
logs/
saves/
world/
crash-reports/
.local/

# KubeJS cache
kubejs/probe/
kubejs/.cache/

# Luanti build artifacts
luanti/engine/bin/
luanti/engine/CMakeCache.txt
luanti/engine/CMakeFiles/
luanti/engine/cmake_install.cmake
luanti/engine/lib/
luanti/engine/Makefile
luanti/engine/*.cmake

# Go build artifacts
luanti/proxy/mt-multiserver-proxy
luanti/nexus_plugin/nexus.so
luanti/proxy/plugins/*.so

# World data (generated at runtime)
luanti/worlds/alpha/map.sqlite
luanti/worlds/alpha/map_*.txt
luanti/worlds/alpha/env_meta.txt
luanti/worlds/alpha/auth.txt
luanti/worlds/alpha/players/
luanti/worlds/alpha/mod_storage/
luanti/worlds/beta/map.sqlite
luanti/worlds/beta/map_*.txt
luanti/worlds/beta/env_meta.txt
luanti/worlds/beta/auth.txt
luanti/worlds/beta/players/
luanti/worlds/beta/mod_storage/

# Proxy data
luanti/proxy/auth/
luanti/proxy/players.sqlite
luanti/proxy/cache/

# Dependencies (cloned, not tracked)
luanti/engine/
luanti/proxy/
luanti/chatcommands/

# Secrets
luanti/config/nexus_secret
